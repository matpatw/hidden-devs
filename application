local ServerStorage = game:GetService("ServerStorage")

local CaveGenerator = {}
local BLOCK_SIZE = 4

local BATCH_SIZE = 50    
local WAIT_TIME = 0.02   

function CaveGenerator.GetOres()
	local setupFolder = ServerStorage:WaitForChild("CaveSetup")
	local oresFolder = setupFolder:WaitForChild("Ores")
	local oreModule = oresFolder:WaitForChild("AllOres")
	local oreTable = require(oreModule)

	local ores = {}
	for _, oreData in pairs(oreTable) do
		table.insert(ores, oreData)
	end

	return ores
end

function CaveGenerator.PickOre(ores)
	CaveGenerator.GetOres()
	local totalChance = 0
	for _, ore in ipairs(ores) do
		totalChance += ore.Chance
	end

	local rand = math.random() * totalChance
	local running = 0

	for _, ore in ipairs(ores) do
		running += ore.Chance
		if rand <= running then
			return ore
		end
	end

	return nil
end

local RunService = game:GetService("RunService")

function CaveGenerator.Generate(part)
	
	CaveGenerator.GetOres()
	
	print("[CaveGenerator] Starting generation...")

	local ores = CaveGenerator.GetOres()
	if #ores == 0 then
		warn("[CaveGenerator] No ores found!")
		return
	end

	local setupFolder = ServerStorage:WaitForChild("CaveSetup")
	local modelsFolder = setupFolder:WaitForChild("Models")

	local container = Instance.new("Folder")
	container.Name = part.Name .. "_Cave"
	container.Parent = workspace

	local size = part.Size
	local minX = part.Position.X - size.X / 2
	local minY = part.Position.Y - size.Y / 2
	local minZ = part.Position.Z - size.Z / 2

	local gridX = math.floor(size.X / BLOCK_SIZE)
	local gridY = math.floor(size.Y / BLOCK_SIZE)
	local gridZ = math.floor(size.Z / BLOCK_SIZE)

	local totalBlocks = gridX * gridY * gridZ
	print("[CaveGenerator] Grid Size:", gridX, gridY, gridZ, "Total:", totalBlocks)

	local x, y, z = 0, 0, 0
	local totalCount = 0
	local spawned = 0

	local connection
	connection = RunService.Heartbeat:Connect(function()

		for i = 1, 180 do
			if x >= gridX then
				connection:Disconnect()
				print("[CaveGenerator] Finished. Spawned:", spawned, "ores")
				return
			end

			local worldX = minX + x * BLOCK_SIZE + BLOCK_SIZE / 2
			local worldY = minY + y * BLOCK_SIZE + BLOCK_SIZE / 2
			local worldZ = minZ + z * BLOCK_SIZE + BLOCK_SIZE / 2

			local blockToSpawn = "Stone"
			if math.random() <= 0.10 then
				local ore = CaveGenerator.PickOre(ores)
				if ore then
					blockToSpawn = ore.Model
				end
			end

			local oreModel = modelsFolder:FindFirstChild(blockToSpawn)
			if oreModel then
				local clone = oreModel:Clone()
				clone.Parent = container

				if clone.PrimaryPart then
					clone:SetPrimaryPartCFrame(CFrame.new(worldX, worldY, worldZ))
				else
					for _, partInModel in ipairs(clone:GetDescendants()) do
						if partInModel:IsA("BasePart") then
							partInModel.CFrame = CFrame.new(worldX, worldY, worldZ)
						end
					end
				end

				spawned += 1
			end

			totalCount += 1
			if totalCount % 500 == 0 then
				print("[CaveGenerator] Progress:", totalCount, "/", totalBlocks)
			end


			z += 1
			if z >= gridZ then
				z = 0
				y += 1
				if y >= gridY then
					y = 0
					x += 1
				end
			end
		end
	end)
end


return CaveGenerator
